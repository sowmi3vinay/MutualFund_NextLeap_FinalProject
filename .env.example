OPENAI_API_KEY=
VECTOR_DB_PATH=./data/vector_store
API_BASE_URL=http://localhost:8000
APP_ENV=local
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174
VECTOR_BACKEND=supabase
# Optional for Phase 2B LLM generation. If missing, the API uses context-only extractive fallback.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Phase 2A local retrieval
EMBEDDING_PROVIDER=sentence-transformers
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_LOCAL_FILES_ONLY=true

# Future deployment target
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_PASSWORD=
SUPABASE_VECTOR_TABLE=document_chunks
ADVISOR_TIMEZONE=Asia/Kolkata
ADVISOR_SLOT_MINUTES=30
ADVISOR_BUSINESS_DAYS=Monday,Tuesday,Wednesday,Thursday,Friday
ADVISOR_BUSINESS_START_HOUR=9
ADVISOR_BUSINESS_END_HOUR=18
ADVISOR_SLOT_INTERVAL_MINUTES=30
ADVISOR_SLOT_HORIZON_DAYS=14
# Deployment-friendly option: paste the full service account JSON into your hosting provider secret store.
GOOGLE_SERVICE_ACCOUNT_JSON=
# Local development fallback only. Do not use a laptop-specific file path in deployment.
GOOGLE_SERVICE_ACCOUNT_FILE=
GOOGLE_SHEETS_BOOKING_SPREADSHEET_ID=
GOOGLE_SHEETS_BOOKING_WORKSHEET=Bookings

# Frontend-only Vapi browser voice integration
VITE_VAPI_PUBLIC_KEY=
VITE_VAPI_ASSISTANT_ID=
